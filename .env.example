# Shopify Storefront API configuration
# Copy this file to `.env.local` and fill in your real values.
# `.env.local` is gitignored — never commit your token.

# Your store's myshopify domain (no https://, no trailing slash)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Storefront API access token (Admin → Settings → Apps and sales channels →
# Develop apps → your app → API credentials → Storefront API access token)
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# Optional — Storefront API version (defaults to 2025-01 if unset)
SHOPIFY_API_VERSION=2025-01

# Optional — collection handles used to populate each page
# (defaults: coffee / merch)
SHOPIFY_COFFEE_COLLECTION=coffee
SHOPIFY_MERCH_COLLECTION=merch
