# Shopify Storefront API configuration
# Copy this file to `.env.local` and fill in your real values.
# `.env.local` is gitignored — never commit your token.

# Your store's myshopify domain (no https://, no trailing slash)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Storefront API access token (Admin → Settings → Apps and sales channels →
# Develop apps → your app → API credentials → Storefront API access token)
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# Optional — Storefront API version (defaults to 2025-01 if unset)
SHOPIFY_API_VERSION=2025-01

# Optional — collection handles used to populate each page
# (defaults: coffee / merch)
SHOPIFY_COFFEE_COLLECTION=coffee
SHOPIFY_MERCH_COLLECTION=merch

# --- Customer Account API (headless sign-in) ---------------------------------
# Powers on-site login / orders via Shopify's Customer Account API (OAuth+PKCE).
# Set these up in the Headless sales channel → Customer Account API → Application
# setup. Register these callback + logout URIs there:
#   callback: https://<your-domain>/api/account/callback  (and http://localhost:3000/api/account/callback)
#   logout:   https://<your-domain>                       (and http://localhost:3000)

# Customer Account API client id (format: shp_…) — required for sign-in
SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_ID=

# Optional — only if the channel issues a CONFIDENTIAL client (adds a Basic header)
SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_SECRET=

# Optional — Customer Account API version (defaults to 2025-10)
SHOPIFY_CUSTOMER_ACCOUNT_API_VERSION=2025-10

# Optional — public site origin used to build OAuth redirect URIs.
# Leave unset to derive it from the incoming request. Set in production to be safe.
# e.g. https://daily-grind-tau.vercel.app
NEXT_PUBLIC_SITE_URL=

# --- Contact / Wholesale form delivery ---------------------------------------
# Submissions are emailed to you via Resend (https://resend.com). Create a free
# account, add an API key, and set the destination address below.

# Resend API key (re_…)
RESEND_API_KEY=

# Where form submissions are emailed (your inbox)
INQUIRY_TO_EMAIL=

# From address. Use Resend's test sender until you verify your own domain.
INQUIRY_FROM_EMAIL=Daily Grind <onboarding@resend.dev>

# Optional alternative — POST submissions to a webhook instead of emailing
# (used only if RESEND_API_KEY/INQUIRY_TO_EMAIL are not set).
INQUIRY_WEBHOOK_URL=
